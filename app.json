{
  "expo": {
    "name": "SevenBites",
    "slug": "SevenBites",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sevenbites",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SevenBites needs your location to find restaurants near you and auto-fill your delivery address.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SevenBites needs your location to find restaurants near you and auto-fill your delivery address."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#E23744"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "package": "com.sevenbites.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 260,
          "resizeMode": "contain",
          "backgroundColor": "#E23744",
          "ios": {
            "image": "./assets/images/icon.png",
            "imageWidth": 260,
            "resizeMode": "contain",
            "backgroundColor": "#E23744"
          },
          "android": {
            "image": "./assets/images/icon.png",
            "imageWidth": 260,
            "resizeMode": "contain",
            "backgroundColor": "#E23744"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SevenBites needs your location to find restaurants near you and auto-fill your delivery address."
        }
      ],
      "expo-secure-store",
      "expo-font",
      [
        "@rnmapbox/maps",
        {}
      ],
      "@react-native-google-signin/google-signin"
    ],
    
    "extra": {
      "apiBaseUrl": "https://sevenbites-restaurant-backend.onrender.com/api",
      "eas": {
        "projectId": "14365027-eead-4c32-a015-d4bb56057536"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/14365027-eead-4c32-a015-d4bb56057536"
    }
  }
}
